generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String
  displayName   String
  profilePicture String?
  email         String
  password      String
  linkedSEOs    String[] @default([])
  subscriptionPlan      String   @default("free")
  subscriptionStartedAt DateTime @default(now())
  subscriptionEndsAt    DateTime?
  emailVerified Boolean  @default(false)
  emailVerificationToken          String?
  emailVerificationTokenExpiresAt DateTime?
  deleted       Boolean  @default(false)
  deletedAt     DateTime?
  disabled      Boolean  @default(false)
  disabledAt    DateTime?
  disabledUntil DateTime?
  institution   String?
  program       String?
  posts         Post[]   @relation("UserPosts")
  likes         Like[]
  comments      Comment[]
  commentLikes  CommentLike[]
  seoAccounts   SeoAccount[]
  workspace     Workspace?
  archive       Archive?
  followerRelations Follow[] @relation("UserFollowers")
  followingRelations Follow[] @relation("UserFollowing")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([username])
  @@index([email])
}

enum SeoProvider {
  GOOGLE
  FACEBOOK
}

model SeoAccount {
  id             String      @id @default(cuid())
  userId         String
  provider       SeoProvider
  providerUserId String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
}

model Post {
  id         String   @id @default(cuid())
  fileUrl    String
  thumbnailUrl String?
  pinned     Boolean  @default(false)
  commentsDisabled Boolean @default(false)
  title      String
  courseCode String
  description String?
  year       Int?
  authorId   String?
  author     User?    @relation("UserPosts", fields: [authorId], references: [id], onDelete: SetNull)
  likes      Like[]
  comments   Comment[]
  savedInWorkspaces WorkspaceSavedPost[]
  savedInArchives ArchiveSavedPost[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([authorId])
  @@index([courseCode])
}

model Workspace {
  id        String               @id @default(cuid())
  userId    String               @unique
  name      String               @default("My Workspace")
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders   WorkspaceFolder[]
  savedPosts WorkspaceSavedPost[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model WorkspaceFolder {
  id          String               @id @default(cuid())
  workspaceId String
  name        String
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  savedPosts  WorkspaceSavedPost[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model WorkspaceSavedPost {
  id          String           @id @default(cuid())
  workspaceId String
  folderId    String?
  postId      String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folder      WorkspaceFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  post        Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())

  @@unique([workspaceId, postId])
  @@index([workspaceId, folderId])
  @@index([postId])
}

model Archive {
  id         String            @id @default(cuid())
  userId     String            @unique
  name       String            @default("My Archive")
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  folders    ArchiveFolder[]
  savedPosts ArchiveSavedPost[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model ArchiveFolder {
  id        String             @id @default(cuid())
  archiveId String
  name      String
  archive   Archive            @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  savedPosts ArchiveSavedPost[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([archiveId, name])
  @@index([archiveId])
}

model ArchiveSavedPost {
  id        String         @id @default(cuid())
  archiveId String
  folderId  String?
  postId    String
  archive   Archive        @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  folder    ArchiveFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  post      Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([archiveId, postId])
  @@index([archiveId, folderId])
  @@index([postId])
}

model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post       Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Comment[]     @relation("CommentReplies")
  commentLikes CommentLike[]

  @@index([postId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId])
}

model CommentLike {
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@id([userId, commentId])
  @@index([commentId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}
